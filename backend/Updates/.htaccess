# PyRpiCamController OTA API .htaccess
# Upload this file to /pycamota/ directory on server
# Designed to coexist with WordPress in parent directory

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /pycamota/
    
    # Security: Block direct access to sensitive files
    RewriteRule ^secrets\.php$ - [F,L]
    RewriteRule ^config\.php$ - [F,L]
    RewriteRule ^logs/.*$ - [F,L]
    RewriteRule ^storage/.*$ - [F,L]
    RewriteRule ^\..*$ - [F,L]
    
    # API Routing - only process requests for this subfolder
    # Don't interfere with WordPress URLs
    
    # OTA API endpoints
    RewriteRule ^api/ota/check/?$ api/ota_check.php [L]
    RewriteRule ^api/ota/report/?$ api/ota_report.php [L]
    
    # Version management API
    RewriteRule ^api/versions/?$ api/version_management_new.php [L]
    RewriteRule ^api/versions/([0-9]+)/?$ api/version_management_new.php?id=$1 [L]
    
    # Device management API
    RewriteRule ^api/devices/?$ api/device_management.php [L]
    RewriteRule ^api/devices/([a-zA-Z0-9]+)/?$ api/device_management.php?cpu_id=$1 [L]
    
    # Logs API (if needed)
    RewriteRule ^api/logs/?$ api/ota_report.php?action=logs [L]
    
    # Admin dashboard and authentication
    RewriteRule ^admin/login/?$ admin/admin_login.php [L]
    RewriteRule ^admin/logout/?$ admin/admin_logout.php [L]
    RewriteRule ^admin/?$ admin/admin_dashboard.php [L]
    
    # Debug endpoints (keep only api_test for API testing)
    RewriteRule ^api/test/?$ api/api_test.php [L]
    RewriteRule ^api/simplelist/?$ utils/simple_device_list.php [L]
</IfModule>

<IfModule mod_headers.c>
	Header unset X-Robots-Tag
</IfModule>

<Files wp-config.php>
	<IfModule !mod_authz_core.c>
		order allow,deny
		deny from all
	</IfModule>
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
</Files>

# Disable directory browsing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Limit file upload size (adjust as needed)
php_value upload_max_filesize 50M
php_value post_max_size 50M
php_value max_execution_time 300